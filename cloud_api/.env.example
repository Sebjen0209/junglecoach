# -----------------------------------------------------------------------
# JungleCoach Cloud API — environment variables
# Copy to .env for local development. Never commit .env.
# All of these must also be set as Railway environment variables.
# -----------------------------------------------------------------------

# Anthropic — use claude-sonnet-4-6 in production, haiku for cost testing
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# Riot Games API key (register at developer.riotgames.com)
RIOT_API_KEY=

# Supabase — get these from your Supabase project settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# App
ENVIRONMENT=production
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins (no trailing slash, no wildcards)
# Example: https://junglecoach.gg,https://www.junglecoach.gg
ALLOWED_ORIGINS=
