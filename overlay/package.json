{
  "name": "junglecoach-overlay",
  "version": "0.1.0",
  "description": "JungleCoach real-time gank priority overlay",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "gg.junglecoach.overlay",
    "productName": "JungleCoach",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**"
    ]
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0"
  }
}
