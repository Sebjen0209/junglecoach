{
  "name": "junglecoach-overlay",
  "version": "0.4.0",
  "description": "JungleCoach real-time gank priority overlay",
  "author": "JungleCoach",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "gg.junglecoach.overlay",
    "productName": "JungleCoach",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/junglecoach-backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "Sebjen0209",
      "repo": "junglecoach"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0"
  }
}
